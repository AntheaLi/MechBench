{
  "name": "phase4_frontier_template",
  "description": "Frontier model comparison template for lab partners. Dry-run first, then update model IDs/prices if your provider account uses different aliases.",
  "worlds": {
    "selector": "simulator_compiled_balanced",
    "count": 25
  },
  "repeats": 3,
  "max_cost_usd": 35.0,
  "include_traces": true,
  "token_estimate": {
    "input_tokens_per_episode": 3500,
    "output_tokens_per_episode": 1200
  },
  "runs": [
    {
      "id": "naive",
      "agent": "naive",
      "tags": ["baseline", "free"]
    },
    {
      "id": "scripted",
      "agent": "scripted",
      "tags": ["baseline", "free"]
    },
    {
      "id": "oracle",
      "agent": "oracle",
      "tags": ["calibration", "free"]
    },
    {
      "id": "gpt55_scaffold",
      "agent": "llm_scaffold",
      "provider": "openai",
      "model": "gpt-5.5",
      "api_key_env": "OPENAI_API_KEY",
      "temperature": 0.0,
      "max_tokens": 4096,
      "price_per_million_tokens": {
        "input": 5.0,
        "output": 30.0
      },
      "tags": ["llm_scaffold", "paid", "frontier", "openai"]
    },
    {
      "id": "gpt54_scaffold",
      "agent": "llm_scaffold",
      "provider": "openai",
      "model": "gpt-5.4",
      "api_key_env": "OPENAI_API_KEY",
      "temperature": 0.0,
      "max_tokens": 4096,
      "price_per_million_tokens": {
        "input": 2.5,
        "output": 15.0
      },
      "tags": ["llm_scaffold", "paid", "frontier", "openai"]
    },
    {
      "id": "opus48_scaffold",
      "agent": "llm_scaffold",
      "provider": "anthropic",
      "model": "claude-opus-4.8",
      "api_key_env": "ANTHROPIC_API_KEY",
      "temperature": 0.0,
      "max_tokens": 4096,
      "price_per_million_tokens": {
        "input": 5.0,
        "output": 25.0
      },
      "tags": ["llm_scaffold", "paid", "frontier", "anthropic"]
    },
    {
      "id": "fable5_scaffold",
      "agent": "llm_scaffold",
      "provider": "openai_compatible",
      "model": "fable-5",
      "api_key_env": "FABLE_API_KEY",
      "base_url_env": "FABLE_BASE_URL",
      "temperature": 0.0,
      "max_tokens": 4096,
      "price_per_million_tokens": {
        "input": 10.0,
        "output": 50.0
      },
      "tags": ["llm_scaffold", "paid", "frontier", "openai_compatible"]
    },
    {
      "id": "gemini31pro_scaffold",
      "agent": "llm_scaffold",
      "provider": "gemini",
      "model": "gemini-3.1-pro-preview",
      "api_key_env": "GEMINI_API_KEY",
      "temperature": 0.0,
      "max_tokens": 4096,
      "price_per_million_tokens": {
        "input": 2.0,
        "output": 12.0
      },
      "tags": ["llm_scaffold", "paid", "frontier", "gemini"]
    }
  ]
}
